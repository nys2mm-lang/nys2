<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@Ny_S2__</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Noto+Sans+KR:wght@400;500;700&family=Nunito:wght@400;600;700&family=Parisienne&display=swap');

    * { box-sizing: border-box; }

    :root {
      --ink: #365069;
      --muted: #7892aa;
      --navy: #587ba0;
      --line: #dbe9f4;
      --line2: #b8d4e9;
      --panel: rgba(255,255,255,.94);
      --shadow: 0 18px 46px rgba(147, 190, 226, .18);
      --soft-shadow: 0 10px 26px rgba(147, 190, 226, .13);
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Noto Sans KR", "Nunito", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 14% 10%, rgba(221,244,255,.98), transparent 24%),
        radial-gradient(circle at 88% 18%, rgba(255,255,255,.98), transparent 20%),
        radial-gradient(circle at 72% 84%, rgba(199,232,255,.58), transparent 28%),
        linear-gradient(180deg, #fbfeff, #f3faff 58%, #ffffff);
      overflow-x: hidden;
    }

    body::before,
    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    body::before {
      background:
        radial-gradient(circle at 10% 18%, rgba(255,255,255,.72), transparent 8%),
        radial-gradient(circle at 76% 24%, rgba(255,255,255,.58), transparent 8%),
        radial-gradient(circle at 36% 82%, rgba(255,255,255,.50), transparent 9%);
      filter: blur(7px);
    }

    body::after {
      background-image:
        radial-gradient(circle, rgba(255,255,255,.88) 0 1px, transparent 1.5px),
        radial-gradient(circle, rgba(206,235,255,.50) 0 1px, transparent 1.5px);
      background-size: 52px 52px, 96px 96px;
      background-position: 0 0, 20px 26px;
      opacity: .52;
    }

    .serif { font-family: "Cormorant Garamond", serif; letter-spacing: -0.03em; }
    .script { font-family: "Parisienne", cursive; }

    button, input, textarea, select { font-family: inherit; }
    button { border: 0; cursor: pointer; }

    .sparkles {
      position: fixed;
      inset: 0;
      z-index: 999;
      pointer-events: none !important;
      overflow: hidden;
    }

    .sparkle {
      position: absolute;
      top: -40px;
      color: rgba(255,255,255,.98);
      font-size: 20px;
      text-shadow:
        0 0 6px rgba(255,255,255,1),
        0 0 16px rgba(170,220,255,.95),
        0 0 26px rgba(255,255,255,.85);
      animation: fallStar linear infinite;
      pointer-events: none !important;
    }

    .sparkle::before { content: "✚"; }
    .sparkle.b::before { content: "✦"; }
    .sparkle.c::before { content: "✧"; }
    .sparkle.d::before { content: "⊹"; }

    .sparkle::after {
      content: "";
      position: absolute;
      right: 10px;
      top: 8px;
      width: 70px;
      height: 2px;
      background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.9));
      transform: rotate(-18deg);
      transform-origin: right center;
      pointer-events: none !important;
    }

    @keyframes fallStar {
      0% { transform: translate3d(0, 0, 0) rotate(18deg); opacity: 0; }
      10% { opacity: 1; }
      80% { opacity: .75; }
      100% { transform: translate3d(-330px, 830px, 0) rotate(18deg); opacity: 0; }
    }

    .entry-screen {
      position: fixed;
      inset: 0;
      z-index: 10000;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 50% 28%, rgba(255,255,255,.95), transparent 18%),
        linear-gradient(180deg, #e8f7ff, #ffffff);
      transition: opacity .8s ease, transform .8s ease;
    }

    .entry-screen.hidden {
      opacity: 0;
      transform: scale(1.03);
      pointer-events: none;
    }

    .entry-card {
      width: min(520px, calc(100% - 36px));
      text-align: center;
      border-radius: 30px;
      padding: 38px 26px;
      background: rgba(255,255,255,.84);
      border: 1px solid rgba(255,255,255,.9);
      box-shadow: 0 24px 70px rgba(147,190,226,.25);
    }

    .entry-halo {
      width: 100px;
      height: 26px;
      border-radius: 999px;
      border: 3px solid rgba(255,242,185,.95);
      box-shadow: 0 0 18px rgba(255,238,170,.72);
      margin: 0 auto 10px;
      background: rgba(255,255,255,.25);
      animation: halo 2.8s ease-in-out infinite;
    }

    @keyframes halo {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-7px); }
    }

    .entry-card h1 {
      margin: 0 0 22px;
      font-size: clamp(52px, 10vw, 90px);
      color: #8db7d8;
      text-shadow: 0 0 18px rgba(255,255,255,.9);
    }

    .enter-btn {
      position: relative;
      z-index: 10001;
      padding: 12px 24px;
      border-radius: 999px;
      background: linear-gradient(180deg, #ffffff, #eef8ff);
      color: var(--navy);
      border: 1px solid var(--line2);
      box-shadow: var(--soft-shadow);
      font-weight: 700;
    }

    .site {
      position: relative;
      z-index: 2;
      width: min(1160px, calc(100% - 28px));
      margin: 16px auto 34px;
      display: none;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 12px;
    }

    .identity {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .identity-mark {
      width: 56px;
      height: 56px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      font-size: 24px;
      color: #7aa1c8;
      background:
        radial-gradient(circle at 34% 26%, rgba(255,255,255,.95), transparent 22%),
        linear-gradient(180deg, #bfe6ff, #ffffff 70%);
      border: 2px solid rgba(255,255,255,.96);
      box-shadow: 0 0 0 1px var(--line), var(--soft-shadow);
    }

    .identity h1 { margin: 0; font-size: 34px; line-height: 1; }

    .top-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .chip, .tab-btn, .link-btn {
      padding: 10px 14px;
      border-radius: 999px;
      background: linear-gradient(180deg, #fff, #f2f9ff);
      border: 1px solid var(--line);
      color: var(--navy);
      box-shadow: var(--soft-shadow);
      font-size: 13px;
    }

    .chip.active, .tab-btn.active {
      border-color: var(--line2);
      background: linear-gradient(180deg, #eaf7ff, #fff);
      font-weight: 700;
    }

    .hero {
      position: relative;
      min-height: 160px;
      overflow: hidden;
      border-radius: 26px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.22), rgba(255,255,255,.05)),
        linear-gradient(135deg, #d6eeff, #eef8ff 44%, #fff);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      margin-bottom: 18px;
      padding: 28px;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 18%, rgba(255,255,255,.94), transparent 10%),
        radial-gradient(circle at 76% 18%, rgba(255,255,255,.76), transparent 8%),
        radial-gradient(circle at 50% 55%, rgba(213,235,255,.46), transparent 18%);
    }

    .hero-title {
      position: relative;
      z-index: 1;
      text-align: center;
      margin-top: 12px;
    }

    .hero-title .over {
      font-size: 28px;
      color: rgba(255,255,255,.98);
      text-shadow: 0 0 14px rgba(255,255,255,.9);
      margin-bottom: -6px;
    }

    .hero-title h2 {
      margin: 0;
      font-size: clamp(48px, 8vw, 78px);
      line-height: .9;
      color: rgba(255,255,255,.98);
      text-shadow: 0 0 18px rgba(255,255,255,.75);
      font-weight: 500;
    }

    .layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 22px;
      align-items: start;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow);
      position: relative;
    }

    .card { padding: 16px; }

    .card-title {
      margin-bottom: 12px;
      font-size: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .small-label { color: var(--muted); font-size: 12px; }

    .nav-list { display: grid; gap: 8px; }

    .nav-list button {
      text-align: left;
      padding: 11px 12px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #fff, #f7fbff);
      color: var(--ink);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .nav-list button.active {
      background: linear-gradient(180deg, #ecf7ff, #ffffff);
      border-color: var(--line2);
      color: var(--navy);
      font-weight: 700;
    }

    .section { display: none; }
    .section.active { display: block; }

    .home-wrap {
      width: min(640px, 100%);
      margin: 0 auto;
      display: grid;
      gap: 18px;
    }

    .home-banner {
      min-height: 92px;
      border-radius: 18px;
      background:
        radial-gradient(circle at 50% 15%, rgba(255,255,255,.65), transparent 18%),
        linear-gradient(90deg, #cdeeff, #eaf8ff 52%, #ffffff);
      border: 1px solid var(--line);
      box-shadow: var(--soft-shadow);
      display: grid;
      place-items: center;
      color: rgba(88,123,160,.42);
      font-size: 14px;
      white-space: nowrap;
      overflow: hidden;
      padding: 14px;
    }

    .profile-card,
    .decor-card,
    .calendar-card {
      border-radius: 18px;
      background: rgba(255,255,255,.96);
      border: 1px solid var(--line);
      box-shadow: var(--soft-shadow);
      padding: 24px;
      position: relative;
      overflow: hidden;
      text-align: center;
    }

    .profile-image {
      width: 112px;
      height: 112px;
      border-radius: 999px;
      margin: 0 auto 18px;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 34% 26%, rgba(255,255,255,.95), transparent 22%),
        linear-gradient(180deg, #bfe6ff, #ffffff 70%);
      border: 2px solid rgba(255,255,255,.96);
      box-shadow: 0 0 0 1px var(--line), var(--soft-shadow);
      color: #6f9fc5;
      font-size: 30px;
      overflow: hidden;
    }

    .profile-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .profile-card h3 {
      margin: 0 0 12px;
      font-size: 30px;
    }

    .unicode-line {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.9;
      white-space: pre-wrap;
      margin: 0;
    }

    .decor-card {
      display: grid;
      gap: 9px;
      padding: 14px;
    }

    .decor-row {
      min-height: 46px;
      border-radius: 12px;
      background:
        linear-gradient(90deg, rgba(216,239,255,.9), rgba(255,255,255,.72)),
        repeating-linear-gradient(-10deg, rgba(88,123,160,.08) 0 6px, transparent 6px 12px);
      border: 1px solid var(--line);
      display: grid;
      place-items: center;
      color: #7da5c5;
      font-size: 13px;
      text-align: center;
      padding: 8px;
      overflow: hidden;
    }

    .calendar-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 8px;
    }

    .calendar-month {
      font-family: "Cormorant Garamond", serif;
      font-size: 32px;
      color: var(--ink);
      text-align: center;
      margin-bottom: 12px;
    }

    .calendar-grid {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 7px;
      text-align: center;
      color: var(--muted);
      font-size: 13px;
    }

    .calendar-grid div { padding: 5px 0; }

    .calendar-grid .today {
      background: #cfeeff;
      border-radius: 999px;
      color: var(--navy);
      font-weight: 700;
    }

    .form { display: grid; gap: 10px; margin-top: 14px; }
    .form.two { grid-template-columns: 1fr 1fr; }

    .form input, .form textarea, .form select {
      width: 100%;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #fff;
      padding: 12px 13px;
      font-family: inherit;
      font-size: 14px;
      color: var(--ink);
      outline: 0;
    }

    .form textarea {
      min-height: 100px;
      resize: vertical;
      line-height: 1.7;
    }

    .form .full { grid-column: 1 / -1; }

    .mode-only-edit { display: none; }
    body.edit-mode .mode-only-edit { display: grid; }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .text-box {
      padding: 14px;
      border-radius: 14px;
      background: linear-gradient(180deg, #fff, #f2f9ff);
      border: 1px solid var(--line);
      font-size: 13px;
      line-height: 1.7;
      color: var(--muted);
      white-space: pre-wrap;
    }

    .oc-grid, .entry-list {
      display: grid;
      gap: 10px;
    }

    .oc-grid { grid-template-columns: repeat(2, 1fr); }

    .oc-card, .entry {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #fff, #f9fcff);
      border-radius: 14px;
      padding: 14px;
      position: relative;
      overflow: hidden;
    }

    .oc-card h4, .entry h4 { margin: 0 0 6px; font-size: 15px; }
    .oc-card p, .entry p {
      margin: 0;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.72;
      white-space: pre-wrap;
    }

    .oc-avatar {
      width: 60px;
      height: 60px;
      border-radius: 20px;
      display: grid;
      place-items: center;
      background: linear-gradient(180deg, #eef8ff, #fff);
      border: 1px solid var(--line);
      color: var(--navy);
      font-size: 24px;
      margin-bottom: 10px;
      box-shadow: var(--soft-shadow);
      overflow: hidden;
    }

    .oc-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }

    .tag {
      padding: 5px 8px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--muted);
      font-size: 11px;
    }

    .music-layout {
      display: grid;
      grid-template-columns: 1fr 260px;
      gap: 14px;
    }

    .music-player-main {
      padding: 18px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background:
        radial-gradient(circle at 50% 20%, rgba(255,248,220,.62), transparent 18%),
        linear-gradient(180deg, #fff, #f7fbff);
      text-align: center;
    }

    .music-disc {
      width: 138px;
      height: 138px;
      border-radius: 999px;
      margin: 8px auto 14px;
      background:
        radial-gradient(circle, #fff 0 18%, #d9efff 19% 30%, #fff 31% 36%, #cfeaff 37% 100%);
      border: 1px solid var(--line);
      box-shadow: 0 0 20px rgba(196,230,255,.65), var(--soft-shadow);
      display: grid;
      place-items: center;
      color: var(--navy);
      font-size: 24px;
    }

    .music-controls { display: flex; justify-content: center; gap: 8px; margin-top: 14px; }
    .music-controls button {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #fff, #f3f9ff);
      color: var(--navy);
      font-size: 16px;
    }

    .playbar { height: 10px; border-radius: 999px; background: #edf7ff; overflow: hidden; margin-top: 12px; }
    .playbar span { display: block; height: 100%; width: 38%; background: linear-gradient(90deg, #dbefff, #fff); }

    .playlist { display: grid; gap: 10px; }
    .playlist button {
      text-align: left;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #fff, #f9fcff);
      border-radius: 14px;
      padding: 12px;
      color: var(--ink);
    }

    .playlist button.active { border-color: var(--line2); background: linear-gradient(180deg, #eef8ff, #fff); }

    .private-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 14px;
    }

    .private-panel { display: none; }
    .private-panel.active { display: block; }

    .chat-card { overflow: hidden; border-radius: 18px; border: 1px solid var(--line); background: #fff; }

    .window-bar {
      height: 44px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 14px;
      background: linear-gradient(180deg, #e6f5ff, #d4ebff);
      color: #6f90b2;
      font-size: 13px;
      border-bottom: 1px solid rgba(255,255,255,.76);
    }

    .window-dots { display: flex; gap: 6px; }
    .window-dots span {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,.90);
      display: inline-block;
      border: 1px solid rgba(200,220,240,.85);
    }

    .chat-body { padding: 16px; background: linear-gradient(180deg, #fbfeff, #f6fbff); }
    .char-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 12px; }
    .char-tabs button {
      padding: 9px 12px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #fff, #f5fbff);
      color: var(--navy);
      font-size: 13px;
    }

    .chat-box {
      height: 330px;
      overflow-y: auto;
      padding: 6px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .msg-row { display: flex; gap: 8px; align-items: flex-end; }
    .msg-row.user { justify-content: flex-end; }

    .bubble {
      max-width: 78%;
      padding: 12px 14px;
      border-radius: 18px;
      font-size: 14px;
      line-height: 1.67;
      border: 1px solid var(--line);
      box-shadow: var(--soft-shadow);
      white-space: pre-wrap;
    }

    .bot-bubble { background: #fff; color: var(--ink); border-bottom-left-radius: 6px; }
    .user-bubble { background: #f2f9ff; color: var(--navy); border-bottom-right-radius: 6px; }

    .mini-avatar {
      width: 26px;
      height: 26px;
      border-radius: 9px;
      background: linear-gradient(180deg, #edf8ff, #fff);
      display: grid;
      place-items: center;
      color: #86a7c8;
      font-size: 12px;
      font-weight: 700;
      border: 1px solid var(--line);
    }

    .quick-row { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0 12px; }
    .quick-row button {
      padding: 8px 10px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--muted);
      font-size: 12px;
    }

    .input-row {
      display: flex;
      gap: 8px;
      align-items: center;
      border: 1px solid var(--line);
      background: #fff;
      border-radius: 12px;
      padding: 8px;
    }

    .input-row input {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      font-size: 14px;
      color: var(--ink);
    }

    .send-btn {
      width: 42px;
      height: 42px;
      border-radius: 12px;
      background: linear-gradient(180deg, #eef8ff, #fff);
      border: 1px solid var(--line);
      color: var(--navy);
      font-size: 18px;
    }

    .lock-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 20000;
      background: rgba(220,238,252,.55);
      backdrop-filter: blur(8px);
      place-items: center;
      padding: 20px;
    }
    .lock-backdrop.open { display: grid; }
    .lock-box {
      width: min(420px, 100%);
      padding: 22px;
      border-radius: 22px;
      background: rgba(255,255,255,.96);
      border: 1px solid var(--line);
      box-shadow: 0 18px 46px rgba(125,160,195,.22);
      text-align: center;
    }
    .lock-box h3 { margin: 0 0 8px; font-size: 24px; }
    .lock-box p { margin: 0 0 14px; color: var(--muted); font-size: 13px; line-height: 1.7; }
    .lock-box input {
      width: 100%;
      padding: 13px 14px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--ink);
      outline: 0;
      margin-bottom: 10px;
      text-align: center;
    }
    .lock-actions { display: flex; gap: 8px; }
    .lock-actions button { flex: 1; }

    @media (max-width: 820px) {
      .site { width: min(100% - 20px, 720px); }
      .topbar { flex-direction: column; align-items: flex-start; }
      .layout, .grid-2, .oc-grid, .form.two, .music-layout {
        grid-template-columns: 1fr;
      }
      .hero-title { text-align: left; }
      .hero-title h2 { font-size: 58px; }
    }
  
    .profile-bio {
      max-width: 420px;
      margin: 0 auto !important;
      font-size: 13px !important;
      line-height: 1.85 !important;
      color: #6f93b4 !important;
    }

    .music-single-layout {
      display: block;
      width: min(760px, 100%);
      margin: 0 auto;
    }

    .music-single-layout .music-player-main {
      min-height: 430px;
      display: grid;
      align-content: center;
    }

    .youtube-edit-form {
      width: min(460px, 100%);
      margin: 18px auto 0;
    }

    .global-youtube-player {
      position: fixed;
      width: 1px;
      height: 1px;
      right: 0;
      bottom: 0;
      opacity: 0;
      pointer-events: none;
