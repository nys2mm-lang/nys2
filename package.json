      const oldRender = window.renderYouTube;
      window.renderYouTube = function () {
        const data = window.getYouTubeData();
        if (qs("musicTitle")) qs("musicTitle").textContent = data.title || "Music Box";
        if (qs("musicArtist")) qs("musicArtist").textContent = data.artist || "YouTube";
        if (qs("youtubeTitle")) qs("youtubeTitle").value = data.title || "";
        if (qs("youtubeArtist")) qs("youtubeArtist").value = data.artist || "";
        if (qs("youtubeUrl")) qs("youtubeUrl").value = data.url || "";
        if (qs("musicHelp")) qs("musicHelp").textContent = "";
      };
    })();
  </script>


  <script>
    // Cloud Sync v1: localStorage changes -> Netlify Blobs via Function.
    // 같은 사이트를 휴대폰/컴퓨터/친구가 열어도 저장 내용이 공유되게 해주는 레이어.
    (function () {
      const SYNC_KEYS = new Set(["activeDreamCharacterId", "dreamCharacterChatMessages", "dreamCharacterChatMessagesV2", "dreamCharacterChatMessagesV3", "dreamCharacterTalkMessages", "dreamCharacterTalkMessagesApiReady", "dreamCharacterTalkMessagesV3", "dreamCharactersList", "dreamTalkSettings", "homeData", "nyChatCleared", "nyDreamChatMessages", "nyDreamTalkMessages", "nySecretDiaryEntries", "nyTodoEntries", "ocClosetData", "shellDiary", "shellHome", "shellHomeData", "shellOCs", "shellProfile", "shellSchedule", "shellYouTube", "soluluChatMessages", "soluluTalkMessages", "soluluTalkMessagesStable", "soluluTalkMessagesV2"]);
      const API_URL = "/.netlify/functions/site-state";
      let applyingCloudState = false;
      let syncTimer = null;

      const rawSetItem = Storage.prototype.setItem;
      const rawRemoveItem = Storage.prototype.removeItem;

      function getSyncPassword() {
        return sessionStorage.getItem("nySyncPassword") || "";
      }

      function rememberSyncPassword(value) {
        const pw = String(value || "").trim();
        if (pw) sessionStorage.setItem("nySyncPassword", pw);
      }

      window.nyRememberSyncPassword = rememberSyncPassword;

      function collectState() {
        const state = {};
        SYNC_KEYS.forEach(key => {
          const value = localStorage.getItem(key);
          if (value !== null) state[key] = value;
        });
        return state;
      }

      function applyState(state) {
        if (!state || typeof state !== "object") return;
        applyingCloudState = true;
        try {
          SYNC_KEYS.forEach(key => rawRemoveItem.call(localStorage, key));
          Object.entries(state).forEach(([key, value]) => {
            if (SYNC_KEYS.has(key) && value !== null && value !== undefined) {
              rawSetItem.call(localStorage, key, String(value));
            }
          });
        } finally {
          applyingCloudState = false;
        }
        rerenderAll();
      }

      function rerenderAll() {
        [
          "renderHome",
          "renderOCs",
          "renderYouTube",
          "renderDiary",
          "renderScheduleCalendar",
          "renderHomeCalendar",
          "renderTodoPanel",
          "renderMessages",
          "renderTalk",
          "renderDreamCharacterSelect",
          "renderCharacterLabels",
          "renderTalkSettings",
          "renderOCCloset"
        ].forEach(name => {
          try {
            if (typeof window[name] === "function") window[name]();
          } catch (e) {}
        });
      }

      async function loadCloudState() {
        try {
          const res = await fetch(API_URL, { method: "GET", cache: "no-store" });
          if (!res.ok) return;
          const data = await res.json();
          if (data && data.state) applyState(data.state);
        } catch (e) {
          console.warn("cloud sync load failed", e);
        }
      }

      async function saveCloudState() {
        const password = getSyncPassword();
        // SITE_PASSWORD를 Netlify에 설정했다면 비밀번호를 모르면 서버 저장은 거부돼.
        try {
          await fetch(API_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              password,
              state: collectState()
            })
          });
        } catch (e) {
          console.warn("cloud sync save failed", e);
        }
      }

      function scheduleSync(key) {
        if (applyingCloudState || !SYNC_KEYS.has(key)) return;
        clearTimeout(syncTimer);
        syncTimer = setTimeout(saveCloudState, 550);
      }

      Storage.prototype.setItem = function (key, value) {
        rawSetItem.call(this, key, value);
        if (this === localStorage) scheduleSync(key);
      };

      Storage.prototype.removeItem = function (key) {
        rawRemoveItem.call(this, key);
        if (this === localStorage) scheduleSync(key);
      };

      // 편집모드/비밀방/clear 비밀번호를 입력하면 그 값을 서버 저장용 비밀번호로도 기억.
      document.addEventListener("input", function (event) {
        if (event.target && event.target.type === "password") {
          rememberSyncPassword(event.target.value);
        }
      }, true);

      document.addEventListener("keydown", function (event) {
        if (event.key === "Enter" && event.target && event.target.type === "password") {
          rememberSyncPassword(event.target.value);
        }
      }, true);

      window.addEventListener("DOMContentLoaded", loadCloudState);
      window.nyLoadCloudState = loadCloudState;
      window.nySaveCloudState = saveCloudState;
    })();
  </script>

</body>
</html>
