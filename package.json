      const countFor = key => allEntries.filter(entry => entry.dateKey === key).length;
      const todayKey = getTodayKey();

      grid.innerHTML = "";
      ["일","월","화","수","목","금","토"].forEach(day => {
        const el = document.createElement("div");
        el.className = "calendar-weekday";
        el.textContent = day;
        grid.appendChild(el);
      });

      for (let i = 0; i < 42; i++) {
        let dayNum, cellMonth = month, cellYear = year, other = false;
        if (i < startWeekday) {
          dayNum = prevDays - startWeekday + i + 1;
          cellMonth = month - 1;
          if (cellMonth < 0) { cellMonth = 11; cellYear -= 1; }
          other = true;
        } else if (i >= startWeekday + daysInMonth) {
          dayNum = i - (startWeekday + daysInMonth) + 1;
          cellMonth = month + 1;
          if (cellMonth > 11) { cellMonth = 0; cellYear += 1; }
          other = true;
        } else {
          dayNum = i - startWeekday + 1;
        }

        const key = `${cellYear}-${String(cellMonth + 1).padStart(2, "0")}-${String(dayNum).padStart(2, "0")}`;
        const count = countFor(key);
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className =
          "calendar-day" +
          (other ? " other-month" : "") +
          (key === todayKey ? " today" : "") +
          (key === selectedDateKey ? " selected" : "");

        const icons = count > 0
          ? `<div class="shell-indicators">${Array.from({ length: Math.min(count, 3) }).map(() => getShellIcon()).join("")}${count > 3 ? `<span class="shell-more">+${count - 3}</span>` : ""}</div>`
          : `<div class="shell-indicators"></div>`;

        btn.innerHTML = `<span class="day-number">${dayNum}</span>${icons}`;
        btn.onclick = () => onSelect(key, cellYear, cellMonth);
        grid.appendChild(btn);
      }

      if ($(noteId)) $(noteId).textContent = allEntries.length ? "날짜를 누르면 일정을 볼 수 있어요." : "아직 일정이 없어요.";
    }

    function renderHomeCalendar() {
      renderCalendarInto("homeCalendarGrid", "homeCalendarYearLabel", "homeCalendarMonthLabel", "homeCalendarNote", homeCalendarDate, (key, year, month) => {
        selectedDateKey = key;
        homeCalendarDate = new Date(year, month, 1);
        calendarDate = new Date(year, month, 1);
        renderHomeCalendar();
        renderScheduleCalendar();
        renderTodoPanel();
      });
    }

    function changeHomeCalendarMonth(offset) {
      homeCalendarDate = new Date(homeCalendarDate.getFullYear(), homeCalendarDate.getMonth() + offset, 1);
      renderHomeCalendar();
    }


    function changeCalendarMonth(offset) {
      calendarDate = new Date(calendarDate.getFullYear(), calendarDate.getMonth() + offset, 1);
      renderScheduleCalendar();
      renderHomeCalendar();
      renderTodoPanel();
    }


    let talkMessages = JSON.parse(localStorage.getItem("soluluTalkMessagesStable") || "[]");
    let talkReplyTimer = null;
    let talkIsTyping = false;
    

    function getTalkTime() {
      const now = new Date();
      return `${String(now.getHours()).padStart(2, "0")}:${String(now.getMinutes()).padStart(2, "0")}`;
    }

    function saveTalkMessages() {
      localStorage.setItem("soluluTalkMessagesStable", JSON.stringify(talkMessages));
    }


    function buildTalkSystemPrompt() {
      const settings = typeof getBotSettings === "function" ? getBotSettings() : {};
      const talkSettings = typeof getTalkSettings === "function" ? getTalkSettings() : {};
      const characterName = typeof getCharacterName === "function" ? getCharacterName() : "소루루";

      return [
        "너는 현재 선택된 드림 캐릭터 역할로 사용자와 문자/카톡을 주고받는다.",
        "응답은 톡처럼 짧고 자연스럽게 한다.",
        "캐릭터가 직접 보낸 메시지만 작성한다.",
        "",
        "[현재 선택된 드림 캐릭터]",
        characterName,
        "",
        "[캐릭터 설정]",
        settings.character || "(아직 상세 캐릭터 설정 없음)",
        "",
        "[말투 설정]",
        settings.speech || "(아직 말투 설정 없음)",
        "",
        "[드림 모드 설정]",
        settings.dream || "(아직 드림 모드 설정 없음)",
        "",
        "[Talk 전용 캐해석]",
        talkSettings.interpretation || "(아직 Talk 전용 캐해석 없음)",
        "",
        "[Talk 전용 분위기]",
        talkSettings.mood || "(아직 Talk 전용 분위기 없음)"
      ].join("\n");
    }


    function makeTalkReply(text) {
      const short = String(text || "").trim();
      if (short.includes("뭐해")) return "네 생각하고 있었어.";
      if (short.includes("보고") || short.includes("좋아")) return "나도. 그래서 답장 기다리고 있었어.";
      if (short.includes("힘들") || short.includes("지쳤") || short.includes("우울")) return "그랬구나. 지금은 나한테 기대도 돼.";
      if (short.includes("?") || short.includes("？")) return "응. 네가 묻는 거라면 대답해주고 싶어.";
      return "응, 읽었어. 조금 더 말해줘.";
    }


    function clearTalkHistory() {
      clearTimeout(talkReplyTimer);
      talkIsTyping = false;
      talkMessages = [];
      localStorage.removeItem("soluluTalkMessagesStable");
      if ($("talkInput")) $("talkInput").disabled = false;
      renderTalk();
    }

    function renderTalk() {
      const screen = $("talkScreen");
      if (!screen) return;
      screen.innerHTML = "";

      if (talkMessages.length === 0 && !talkIsTyping) {
        const empty = document.createElement("div");
        empty.className = "talk-empty";
        empty.textContent = "아직 주고받은 톡이 없어요.";
        screen.appendChild(empty);
      }

      talkMessages.forEach(msg => {
        const row = document.createElement("div");
        row.className = "talk-row " + (msg.role === "me" ? "me" : "bot");

        const bubble = document.createElement("div");
        bubble.className = "talk-bubble " + (msg.role === "me" ? "me" : "bot");
        bubble.textContent = msg.text;

        const time = document.createElement("div");
        time.className = "talk-time";
        time.textContent = msg.time || "";

        if (msg.role === "me") {
          row.appendChild(time);
          row.appendChild(bubble);
        } else {
          row.appendChild(bubble);
          row.appendChild(time);
        }
        screen.appendChild(row);
      });

      if (talkIsTyping) {
        const typingRow = document.createElement("div");
        typingRow.className = "talk-typing-row";
        typingRow.innerHTML = `
          <div class="talk-typing-bubble">
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
          </div>
          <div class="talk-time">typing</div>
        `;
        screen.appendChild(typingRow);
      }

      screen.scrollTop = screen.scrollHeight;
    }

    function sendTalk() {
      const input = $("talkInput");
      const text = input.value.trim();
      if (!text || talkIsTyping) return;

      talkMessages.push({ role: "me", text, time: getTalkTime() });
      input.value = "";
      saveTalkMessages();

      talkIsTyping = true;
      input.disabled = true;
      renderTalk();

      clearTimeout(talkReplyTimer);
      const delay = Math.min(1800, Math.max(650, 420 + text.length * 35));

      talkReplyTimer = setTimeout(() => {
        talkIsTyping = false;
        if ($("talkInput")) $("talkInput").disabled = false;
        talkMessages.push({ role: "bot", text: makeTalkReply(text), time: getTalkTime() });
        saveTalkMessages();
        renderTalk();
      }, delay);
    }

    function quickTalk(text) {
      if (talkIsTyping) return;
      $("talkInput").value = text;
      sendTalk();
    }



    function getTalkSettings() {
      return JSON.parse(localStorage.getItem("dreamTalkSettings") || "{}");
    }

    function saveTalkSettings() {
      const data = {
        interpretation: $("talkCharacterInterpretation") ? $("talkCharacterInterpretation").value.trim() : "",
        mood: $("talkMoodSetting") ? $("talkMoodSetting").value.trim() : ""
      };
      localStorage.setItem("dreamTalkSettings", JSON.stringify(data));
      alert("Talk 설정을 저장했어.");
    }

    function renderTalkSettings() {
      const data = getTalkSettings();
      if ($("talkCharacterInterpretation")) $("talkCharacterInterpretation").value = data.interpretation || "";
      if ($("talkMoodSetting")) $("talkMoodSetting").value = data.mood || "";
      renderDreamCharacterSelect();
    }

    async function saveDreamCharacterFromTalk() {
      const name = $("talkNewCharacterName").value.trim();
      const source = $("talkNewCharacterSource").value.trim();
      const memo = $("talkNewCharacterMemo").value.trim();
      const file = $("talkNewCharacterImage").files[0];

      if (!name) {
        alert("드림 캐릭터 이름을 적어줘.");
        return;
      }

      const image = await readFileAsDataURL(file);
      const id = "char_" + Date.now();
      const chars = getDreamCharacters();
      chars.push({ id, name, source, memo, image });
      saveDreamCharacters(chars);
      localStorage.setItem("activeDreamCharacterId", id);

      ["talkNewCharacterName","talkNewCharacterSource","talkNewCharacterMemo"].forEach(inputId => $(inputId).value = "");
      $("talkNewCharacterImage").value = "";

      renderDreamCharacterSelect();
      renderCharacterLabels();
      alert("드림 캐릭터를 추가했어.");
    }


    setMode("viewer");
    renderHome();
    renderOCs();
    renderYouTube();
    renderMessages();
    renderDiary();
    renderScheduleCalendar();
    renderHomeCalendar();
    renderTodoPanel();
    renderBotSettings();
    renderTalk();
  </script>

  <script>
    window.NY_ALLOWED_PASSWORDS = ["ribbon"];

    function nyNormalizePassword(value) {
      return String(value || "").trim();
    }

    function nyIsPasswordOk(value) {
      return nyNormalizePassword(value) === "ribbon";
    }

    window.enterPrivate = function () {
      const input = document.getElementById("passwordInput");
      if (input && nyIsPasswordOk(input.value)) {
        if (typeof closeGate === "function") closeGate();
        const privateSection = document.getElementById("section-private");
        const privateBtn = document.querySelector('button[onclick*="private"]');
        if (privateSection) {
          document.querySelectorAll(".section").forEach(section => section.classList.remove("active"));
          privateSection.classList.add("active");
        }
        document.querySelectorAll(".menu button").forEach(button => button.classList.remove("active"));
        if (privateBtn) privateBtn.classList.add("active");
      } else {
        alert("비밀번호가 달라!");
      }
    };

    window.nyConfirmEdit = function () {
      const input = document.getElementById("nyEditPassword") || document.getElementById("prettyEditPassword") || document.getElementById("editPasswordInput");
      if (!input || !nyIsPasswordOk(input.value)) {
        alert("비밀번호가 달라!");
        return;
      }

      if (typeof nyCloseModal === "function") nyCloseModal("nyEditGate");
      if (typeof closePrettyModal === "function") closePrettyModal("prettyEditGate");
      const editGate = document.getElementById("editGate");
      if (editGate) editGate.classList.remove("open");

      document.body.classList.add("edit-mode");
      const viewer = document.getElementById("viewerBtn");
      const edit = document.getElementById("editBtn");
      if (viewer) viewer.classList.remove("active");
      if (edit) edit.classList.add("active");
      if (typeof setMode === "function") setMode("edit");
    };

    window.confirmEditGate = window.nyConfirmEdit;
    window.confirmPrettyEdit = window.nyConfirmEdit;

    window.nyConfirmClear = function () {
      const input = document.getElementById("nyClearPassword") || document.getElementById("prettyClearPassword") || document.getElementById("clearPasswordInput");
      if (!input || !nyIsPasswordOk(input.value)) {
        alert("비밀번호가 달라!");
        return;
      }

      const target = window.__nyPendingClear || window.__prettyClearTarget || window.pendingClearTarget || "";

      if (target === "Chat") {
        try { if (typeof chatReplyTimer !== "undefined") clearTimeout(chatReplyTimer); } catch(e) {}
        try { if (typeof chatIsTyping !== "undefined") chatIsTyping = false; } catch(e) {}
        try { if (typeof messages !== "undefined") messages.length = 0; } catch(e) {}
        if (typeof nyMarkChatCleared === "function") nyMarkChatCleared();
        [
          "nyDreamChatMessages",
          "dreamCharacterChatMessages",
          "dreamCharacterChatMessagesV2",
          "dreamCharacterChatMessagesV3",
          "soluluChatMessages"
        ].forEach(key => localStorage.removeItem(key));
        const chatInput = document.getElementById("chatInput");
        if (chatInput) chatInput.disabled = false;
        try { if (typeof renderMessages === "function") renderMessages(); } catch(e) {}
      }

      if (target === "Talk") {
        try { if (typeof talkReplyTimer !== "undefined") clearTimeout(talkReplyTimer); } catch(e) {}
        try { if (typeof talkIsTyping !== "undefined") talkIsTyping = false; } catch(e) {}
        try { if (typeof talkMessages !== "undefined") talkMessages.length = 0; } catch(e) {}
        [
          "nyDreamTalkMessages",
          "soluluTalkMessages",
          "soluluTalkMessagesV2",
          "soluluTalkMessagesStable",
          "dreamCharacterTalkMessages",
          "dreamCharacterTalkMessagesV3",
          "dreamCharacterTalkMessagesApiReady"
        ].forEach(key => localStorage.removeItem(key));
        const talkInput = document.getElementById("talkInput");
        if (talkInput) talkInput.disabled = false;
        try { if (typeof renderTalk === "function") renderTalk(); } catch(e) {}
      }

      if (typeof nyCloseModal === "function") nyCloseModal("nyClearGate");
      if (typeof closePrettyModal === "function") closePrettyModal("prettyClearGate");
      const clearGate = document.getElementById("clearGate");
      if (clearGate) clearGate.classList.remove("open");
    };

    window.confirmClearGate = window.nyConfirmClear;
    window.confirmPrettyClear = window.nyConfirmClear;
  </script>


  <script>
    (function () {
      function qs(id) {
        return document.getElementById(id);
      }

      window.extractYouTubeId = function (url) {
        const text = String(url || "").trim();
        if (!text) return "";
        const patterns = [
          /youtu\.be\/([a-zA-Z0-9_-]{6,})/,
          /youtube\.com\/watch\?[^#]*v=([a-zA-Z0-9_-]{6,})/,
          /youtube\.com\/embed\/([a-zA-Z0-9_-]{6,})/,
          /youtube\.com\/shorts\/([a-zA-Z0-9_-]{6,})/,
          /youtube\.com\/live\/([a-zA-Z0-9_-]{6,})/
        ];
        for (const pattern of patterns) {
          const match = text.match(pattern);
          if (match) return match[1];
        }
        if (/^[a-zA-Z0-9_-]{6,}$/.test(text)) return text;
        return "";
      };

      window.getYouTubeData = function () {
        try {
          return JSON.parse(localStorage.getItem("shellYouTube") || "null") || window.DEFAULT_SHELL_YOUTUBE || {};
        } catch (e) {
          return window.DEFAULT_SHELL_YOUTUBE || {};
        }
      };

      window.saveYouTube = function () {
        const title = qs("youtubeTitle") ? qs("youtubeTitle").value.trim() : "";
        const artist = qs("youtubeArtist") ? qs("youtubeArtist").value.trim() : "";
        const url = qs("youtubeUrl") ? qs("youtubeUrl").value.trim() : "";
        const id = window.extractYouTubeId(url);
        if (!id) {
          alert("유튜브 링크를 확인해줘!");
          return;
        }
        const parsedUrl = new URL(url);
        const list = parsedUrl.searchParams.get("list") || "";
        const t = parsedUrl.searchParams.get("t") || parsedUrl.searchParams.get("start") || "";
        const start = String(t).replace(/s$/, "");
        localStorage.setItem("shellYouTube", JSON.stringify({
          id,
          list,
          start,
          title: title || "저장된 음악",
          artist: artist || "",
          url
        }));
        window.renderYouTube();
        window.startYouTube();
      };

      window.renderYouTube = function () {
        const data = window.getYouTubeData();
        const isPlaying = !!(qs("youtubeFrame") && qs("youtubeFrame").src);
        if (qs("musicTitle")) qs("musicTitle").textContent = data.title || "아직 저장된 음악이 없어요.";
        if (qs("musicArtist")) qs("musicArtist").textContent = data.artist || "";
        if (qs("youtubeTitle")) qs("youtubeTitle").value = data.title || "";
        if (qs("youtubeArtist")) qs("youtubeArtist").value = data.artist || "";
        if (qs("youtubeUrl")) qs("youtubeUrl").value = data.url || "";
        if (qs("playButton")) qs("playButton").textContent = isPlaying ? "⏸" : "▶";
        if (qs("musicProgress")) qs("musicProgress").style.width = isPlaying ? "68%" : "38%";

        const help = qs("musicHelp");
        if (help) {
          help.textContent = "";
        }

        const box = qs("youtubePlayerBox");
        if (box) box.classList.toggle("active", !!data.id && isPlaying);
      };

      window.buildYouTubeSrc = function (id, autoplay) {
        const data = window.getYouTubeData ? window.getYouTubeData() : {};
        const params = new URLSearchParams({
          autoplay: autoplay ? "1" : "0",
          loop: data.list ? "0" : "1",
          controls: "1",
          modestbranding: "1",
          rel: "0",
          playsinline: "1"
        });

        if (data.list) params.set("list", data.list);
        else params.set("playlist", id);

        if (data.start) params.set("start", String(data.start).replace(/s$/, ""));

        return "https://www.youtube.com/embed/" + id + "?" + params.toString();
      };

      window.startYouTube = function () {
        const data = window.getYouTubeData();
        if (!data.id) {
          window.renderYouTube();
          alert("먼저 편집모드에서 유튜브 링크를 저장해줘.");
          return;
        }
        const frame = qs("youtubeFrame");
        if (!frame) {
          alert("유튜브 플레이어를 찾지 못했어.");
          return;
        }
        frame.src = window.buildYouTubeSrc(data.id, true);
        window.renderYouTube();
      };

      window.stopYouTube = function () {
        const frame = qs("youtubeFrame");
        if (frame) frame.src = "";
        window.renderYouTube();
      };

      window.restartYouTube = function () {
        window.stopYouTube();
        setTimeout(window.startYouTube, 180);
      };

      window.toggleYouTube = function () {
        const frame = qs("youtubeFrame");
        if (frame && frame.src) window.stopYouTube();
        else window.startYouTube();
      };

      document.addEventListener("DOMContentLoaded", function () {
        if (typeof window.renderYouTube === "function") window.renderYouTube();
      });
    })();
  </script>


