<div class="lock-backdrop" id="gate">
    <div class="lock-box">
      <h3 class="serif">secret room</h3>
      <p>password</p>
      <input id="passwordInput" type="password" placeholder="password" onkeydown="if(event.key==='Enter') enterPrivate();" />
      <div class="lock-actions">
        <button class="link-btn" type="button" onclick="closeGate()">닫기</button>
        <button class="link-btn" type="button" onclick="enterPrivate()">입장</button>
      </div>
    </div>
  </div>

  <div class="mode-toast" id="modeToast">지금부터 드림모드가 적용됩니다.</div>


  <script>
    const PASSWORD = "ribbon";
    let isPlaying = false;

    const solulu = {
      firstMessage: "안녕. 오늘은 어떤 이야기를 들려줄 거야?",
      sampleReply: "응, 천천히 말해줘. 네가 편하게 이야기할 수 있도록 여기 있을게.",
      quick: [
        "오늘의 네 마음이 어떤 색인지 궁금해.",
        "괜찮아. 지금은 서두르지 않아도 돼.",
        "네 이야기를 조금 더 들려줄래?"
      ]
    };

    let messages = [
      { role: "bot", text: solulu.firstMessage },
      { role: "user", text: "소루루, 오늘은 조금 지쳤어." },
      { role: "bot", text: solulu.sampleReply }
    ];
    let chatIsTyping = false;
    let chatReplyTimer = null;

    function $(id) { return document.getElementById(id); }

    function escapeHtml(text) {
      return String(text || "").replace(/[&<>"']/g, m => ({ "&":"&amp;", "<":"&lt;", ">":"&gt;", '"':"&quot;", "'":"&#039;" }[m]));
    }

    function readFileAsDataURL(file) {
      return new Promise(resolve => {
        if (!file) return resolve("");
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.readAsDataURL(file);
      });
    }

    function enterSite() {
      var entry=document.getElementById('entryScreen');var site=document.getElementById('site');if(entry){entry.classList.add('hidden');setTimeout(function(){entry.style.display='none';},850);}if(site){site.style.display='block';}if(typeof renderHomeCalendar==='function'){renderHomeCalendar();}if(typeof renderScheduleCalendar==='function'){renderScheduleCalendar();}if(typeof renderTodoPanel==='function'){renderTodoPanel();}
    }

    function setMode(mode) {
      document.body.classList.toggle("edit-mode", mode === "edit");
      $("viewerBtn").classList.toggle("active", mode === "viewer");
      $("editBtn").classList.toggle("active", mode === "edit");
    }


    function requestEditMode() {
      const value = prompt("편집모드 비밀번호를 입력해줘.");
      if (value === null) return;
      if (value === PASSWORD) {
        setMode("edit");
      } else {
        alert("비밀번호가 달라!");
      }
    }


    function showSection(id, btn) {
      document.querySelectorAll(".section").forEach(section => section.classList.remove("active"));
      $("section-" + id).classList.add("active");
      document.querySelectorAll(".nav-list button").forEach(button => button.classList.remove("active"));
      if (btn) btn.classList.add("active");
    }

    function openGate() {
      $("gate").classList.add("open");
      setTimeout(() => $("passwordInput").focus(), 50);
    }

    function closeGate() {
      $("gate").classList.remove("open");
      $("passwordInput").value = "";
    }

    function enterPrivate() {
      if ($("passwordInput").value.trim() === PASSWORD) {
        closeGate();
        document.querySelectorAll(".section").forEach(section => section.classList.remove("active"));
        $("section-private").classList.add("active");
        document.querySelectorAll(".nav-list button").forEach(button => button.classList.remove("active"));
      } else {
        alert("비밀번호가 달라!");
      }
    }

    function showPrivatePanel(id, btn) {
      document.querySelectorAll(".private-panel").forEach(panel => panel.classList.remove("active"));
      $("private-" + id).classList.add("active");
      document.querySelectorAll(".private-tabs button").forEach(button => button.classList.remove("active"));
      if (btn) btn.classList.add("active");
      if (id === "talk") renderTalk();
    }

    function getHomeData() {
      return JSON.parse(localStorage.getItem("shellHomeData") || "{}");
    }

    async function saveHome() {
      const data = getHomeData();
      data.title = $("editHomeProfileTitle").value.trim() || data.title || "llem";
      data.text = $("editHomeProfileText").value.trim() || data.text || "𓈒𓏸 𓆩♡𓆪 𓂃 ˚₊‧꒰ა ♡ ໒꒱‧₊˚ 𓂃 𓆩♡𓆪 𓏸𓈒";
      const file = $("profileImageInput").files[0];
      const image = await readFileAsDataURL(file);
      if (image) data.image = image;
      localStorage.setItem("shellHomeData", JSON.stringify(data));
      $("profileImageInput").value = "";
      renderHome();
    }

    function renderHome() {
      const data = getHomeData();
      $("homeProfileTitle").textContent = data.title || "llem";
      $("homeProfileText").textContent = data.text || "𓈒𓏸 𓆩♡𓆪 𓂃 ˚₊‧꒰ა ♡ ໒꒱‧₊˚ 𓂃 𓆩♡𓆪 𓏸𓈒";
      $("editHomeProfileTitle").value = data.title || "";
      $("editHomeProfileText").value = data.text || "";
      if (data.image) {
        $("profileImageBox").innerHTML = `<img src="${data.image}" alt="">`;
      }
    }

    
    function applyPickedOCColor() {
      const picker = $("ocColorPicker");
      const hex = $("ocColorHex");
      if (!picker || !hex) return;
      hex.value = picker.value;
    }

    function resetOCForm() {
      ["ocName","ocKeyword","ocDesc","ocColorHex"].forEach(id => {
        if ($(id)) $(id).value = "";
      });
      if ($("ocColorPicker")) $("ocColorPicker").value = "#9ee7ef";
      if ($("ocImageFile")) $("ocImageFile").value = "";
      if ($("ocEditIndex")) $("ocEditIndex").value = "-1";
    }

    function cancelOCEdit() {
      resetOCForm();
    }

    async function saveOC() {
      const name = $("ocName").value.trim();
      const keyword = $("ocKeyword").value.trim();
      const desc = $("ocDesc").value.trim();
      const colorText = $("ocColorHex").value.trim();
      const pickerColor = $("ocColorPicker").value || "#9ee7ef";
      const color = colorText || pickerColor;
      const editIndex = parseInt($("ocEditIndex") ? $("ocEditIndex").value : "-1", 10);
      const image = await readFileAsDataURL($("ocImageFile").files[0]);

      const ocs = JSON.parse(localStorage.getItem("shellOCs") || "[]");

      if (editIndex >= 0 && ocs[editIndex]) {
        const prev = ocs[editIndex];
        ocs[editIndex] = {
          ...prev,
          name: name || prev.name || "이름 없는 OC",
          keyword: keyword || "",
          color: color || prev.color || "#9ee7ef",
          desc: desc || "",
          image: image || prev.image || ""
        };
      } else {
        if (!name && !keyword && !desc && !image) return;
        ocs.unshift({
          name: name || "이름 없는 OC",
          keyword: keyword || "",
          color: color || "#9ee7ef",
          desc: desc || "",
          image: image || ""
        });
      }

      localStorage.setItem("shellOCs", JSON.stringify(ocs));
      resetOCForm();
      renderOCs();
    }

    function editOC(index) {
      const ocs = JSON.parse(localStorage.getItem("shellOCs") || "[]");
      const oc = ocs[index];
      if (!oc) return;

      if ($("ocEditIndex")) $("ocEditIndex").value = String(index);
      if ($("ocName")) $("ocName").value = oc.name || "";
      if ($("ocKeyword")) $("ocKeyword").value = oc.keyword || "";
      if ($("ocDesc")) $("ocDesc").value = oc.desc || "";
      if ($("ocColorHex")) $("ocColorHex").value = oc.color || "#9ee7ef";
      if ($("ocColorPicker")) $("ocColorPicker").value = /^#[0-9a-fA-F]{6}$/.test(oc.color || "") ? oc.color : "#9ee7ef";

      document.body.classList.add("edit-mode");
      const viewer = $("viewerBtn");
      const edit = $("editBtn");
      if (viewer) viewer.classList.remove("active");
      if (edit) edit.classList.add("active");

      $("section-oc").scrollIntoView({ behavior: "smooth", block: "start" });
    }

    function deleteOC(index) {
      const ocs = JSON.parse(localStorage.getItem("shellOCs") || "[]");
      if (!ocs[index]) return;
      if (!confirm("이 OC를 삭제할까?")) return;
      ocs.splice(index, 1);
      localStorage.setItem("shellOCs", JSON.stringify(ocs));
      resetOCForm();
      renderOCs();
    }

    function renderOCs() {
      const grid = $("ocGrid");
      const ocs = JSON.parse(localStorage.getItem("shellOCs") || "[]");
      if (ocs.length === 0) {
        grid.innerHTML = `<div class="oc-card large"><div class="oc-card-image-large">대표이미지가 아직 없어요.</div><div class="oc-card-body"><h4 class="serif">OC Closet</h4><p class="oc-card-desc">아직 OC가 없어요.</p></div></div>`;
        return;
      }
      grid.innerHTML = "";
      ocs.forEach((oc, index) => {
        const accent = oc.color || '#9ee7ef';
        const card = document.createElement("div");
        card.className = "oc-card large";
        card.style.borderColor = accent + '55';
        card.style.boxShadow = `0 16px 40px ${accent}22`;
        card.innerHTML = `
          <div class="oc-card-image-large">${oc.image ? `<img src="${oc.image}" alt="">` : '대표이미지가 아직 없어요.'}</div>
          <div class="oc-card-body">
            <h4 class="serif">${escapeHtml(oc.name)}</h4>
            ${oc.keyword ? `<div class="oc-pill" style="background:${accent};">${escapeHtml(oc.keyword)}</div>` : ''}
            <p class="oc-card-desc">${escapeHtml(oc.desc || '소개글이 아직 없어요.')}</p>
            <div class="oc-meta-row">
              <span class="tag">${escapeHtml(accent)}</span>
              <span class="oc-color-chip" style="background:${accent};" title="${escapeHtml(accent)}"></span>
            </div>
            <div class="oc-action-row mode-only-edit">
              <button class="oc-action-btn" type="button" onclick="editOC(${index})">수정</button>
              <button class="oc-action-btn delete" type="button" onclick="deleteOC(${index})">삭제</button>
            </div>
          </div>`;
        grid.appendChild(card);
      });
    }


    function extractYouTubeId(url) {
      const text = String(url || "").trim();
      if (!text) return "";
      const patterns = [
        /youtu\.be\/([a-zA-Z0-9_-]{6,})/,
        /youtube\.com\/watch\?[^#]*v=([a-zA-Z0-9_-]{6,})/,
        /youtube\.com\/embed\/([a-zA-Z0-9_-]{6,})/,
        /youtube\.com\/shorts\/([a-zA-Z0-9_-]{6,})/,
        /youtube\.com\/live\/([a-zA-Z0-9_-]{6,})/
      ];
      for (const pattern of patterns) {
        const match = text.match(pattern);
        if (match) return match[1];
      }
      if (/^[a-zA-Z0-9_-]{6,}$/.test(text)) return text;
      return "";
    }

    function getYouTubeData() {
      return JSON.parse(localStorage.getItem("shellYouTube") || "{}");
    }

    function saveYouTube() {
      const title = $("youtubeTitle").value.trim();
      const artist = $("youtubeArtist").value.trim();
      const url = $("youtubeUrl").value.trim();
      const id = extractYouTubeId(url);
      if (!id) {
        alert("유튜브 링크를 확인해줘!");
        return;
      }
      const data = {
        id,
        title: title || "저장된 음악",
        artist: artist || "",
        url
      };
      localStorage.setItem("shellYouTube", JSON.stringify(data));
      renderYouTube();
      startYouTube();
    }

    function renderYouTube() {
      const data = getYouTubeData();
      $("musicTitle").textContent = data.title || "아직 저장된 음악이 없어요.";
      $("musicArtist").textContent = data.artist || "";
      if ($("youtubeTitle")) $("youtubeTitle").value = data.title || "";
      if ($("youtubeArtist")) $("youtubeArtist").value = data.artist || "";
      if ($("youtubeUrl")) $("youtubeUrl").value = data.url || "";

      $("playButton").textContent = isPlaying ? "⏸" : "▶";
      $("musicProgress").style.width = isPlaying ? "68%" : "38%";

      const help = $("musicHelp");
      if (help) {
        help.textContent = "";
      }

      const box = $("youtubePlayerBox");
      if (box) box.classList.toggle("active", !!data.id && isPlaying);
    }

    function buildYouTubeSrc(id, autoplay = true) {
      const params = new URLSearchParams({
        autoplay: autoplay ? "1" : "0",
        loop: "1",
        playlist: id,
        controls: "1",
        modestbranding: "1",
        rel: "0",
        playsinline: "1",
        enablejsapi: "1",
        origin: window.location.origin
      });
      return "https://www.youtube.com/embed/" + id + "?" + params.toString();
    }

    function startYouTube() {
      const data = getYouTubeData();
      if (!data.id) {
        isPlaying = false;
        renderYouTube();
        return;
      }
      const frame = $("youtubeFrame");
      if (!frame) return;
      frame.src = buildYouTubeSrc(data.id, true);
      isPlaying = true;
      renderYouTube();
    }

    function stopYouTube() {
      const frame = $("youtubeFrame");
      if (frame) frame.src = "";
      isPlaying = false;
      renderYouTube();
    }

    function restartYouTube() {
      const data = getYouTubeData();
      if (!data.id) {
        alert("먼저 편집모드에서 유튜브 링크를 저장해줘.");
        return;
      }
      stopYouTube();
      setTimeout(startYouTube, 180);
    }

    function toggleYouTube() {
      const data = getYouTubeData();
      if (!data.id) {
        alert("먼저 편집모드에서 유튜브 링크를 저장해줘.");
        return;
      }
      if (isPlaying) stopYouTube();
      else startYouTube();
    }



    function showModeToast(text) {
      const toast = $("modeToast");
      if (!toast) return;
      toast.textContent = text;
      toast.classList.add("show");
      clearTimeout(window.__modeToastTimer);
      window.__modeToastTimer = setTimeout(() => {
        toast.classList.remove("show");
      }, 500);
    }


    function changeBotMode(mode, button) {
      botMode = mode;

      document.querySelectorAll(".bot-mode-row .tab-btn").forEach(btn => {
        btn.classList.remove("active");
      });
      if (button) button.classList.add("active");

      const visibleLabels = {
        chat: "현재: 채팅",
        basic: "현재: 베이직",
        dream: "현재: 드림"
      };
      const toastLabels = {
        chat: "지금부터 채팅모드가 적용됩니다.",
        basic: "지금부터 베이직모드가 적용됩니다.",
        dream: "지금부터 드림모드가 적용됩니다."
      };

      const label = document.getElementById("botCurrentMode");
      if (label) label.textContent = visibleLabels[mode] || "현재: 채팅";

      if (typeof showModeToast === "function") {
        showModeToast(toastLabels[mode] || "지금부터 채팅모드가 적용됩니다.");
      }
    }

    function safeSetBotMode(mode, button) {
      changeBotMode(mode, button);
    }

    function setBotMode(mode, button) {
      changeBotMode(mode, button);
    }



    function askClearPassword(label) {
      const value = prompt(label + " 내용을 삭제하려면 비밀번호를 입력해줘.");
      if (value === null) return false;
      if (value !== PASSWORD) {
        alert("비밀번호가 달라!");
        return false;
      }
      return confirm(label + " 내용을 전부 삭제할까?");
    }

    function requestClearChat() {
      if (!askClearPassword("Chat")) return;
      if (typeof chatReplyTimer !== "undefined") clearTimeout(chatReplyTimer);
      if (typeof chatIsTyping !== "undefined") chatIsTyping = false;
      if (typeof messages !== "undefined") messages = [];
      [
        "dreamCharacterChatMessages",
        "dreamCharacterChatMessagesV2",
        "dreamCharacterChatMessagesV3",
        "soluluChatMessages"
      ].forEach(key => localStorage.removeItem(key));
      if ($("chatInput")) $("chatInput").disabled = false;
      if (typeof renderMessages === "function") renderMessages();
    }

    function requestClearTalk() {
      if (!askClearPassword("Talk")) return;
      if (typeof talkReplyTimer !== "undefined") clearTimeout(talkReplyTimer);
      if (typeof talkIsTyping !== "undefined") talkIsTyping = false;
      if (typeof talkMessages !== "undefined") talkMessages = [];
      [
        "soluluTalkMessages",
        "soluluTalkMessagesV2",
        "soluluTalkMessagesStable",
        "dreamCharacterTalkMessages",
        "dreamCharacterTalkMessagesV3"
      ].forEach(key => localStorage.removeItem(key));
      if ($("talkInput")) $("talkInput").disabled = false;
      if (typeof renderTalk === "function") renderTalk();
    }



    function getDefaultDreamCharacters() {
      return [{
        id: "solulu",
        name: "소루루",
        source: "프리채널",
        memo: "기본 드림 캐릭터",
        image: ""
      }];
    }

    function getDreamCharacters() {
      const saved = JSON.parse(localStorage.getItem("dreamCharactersList") || "null");
      if (Array.isArray(saved) && saved.length) {
        if (!saved.some(char => char.id === "solulu")) saved.unshift(getDefaultDreamCharacters()[0]);
        return saved;
      }
      return getDefaultDreamCharacters();
    }

    function saveDreamCharacters(list) {
      localStorage.setItem("dreamCharactersList", JSON.stringify(list));
    }

    function getActiveCharacterId() {
      return localStorage.getItem("activeDreamCharacterId") || "solulu";
    }

    function getActiveCharacter() {
      const chars = getDreamCharacters();
      return chars.find(char => char.id === getActiveCharacterId()) || chars[0] || getDefaultDreamCharacters()[0];
    }

    function getCharacterName() {
      return getActiveCharacter().name || "소루루";
    }

    function getCharacterInitial() {
      const name = getCharacterName();
      return name ? name.slice(0, 1) : "소";
    }

    function getCharacterImage() {
      return getActiveCharacter().image || "";
    }

    function makeCharacterIconHTML() {
      const image = getCharacterImage();
      if (image) return `<img src="${image}" alt="">`;
      return escapeHtml(getCharacterInitial());
    }

    function renderDreamCharacterSelect() {
      const chars = getDreamCharacters();
      const active = getActiveCharacterId();

      ["characterSelect", "talkCharacterSelect"].forEach(selectId => {
        const select = $(selectId);
        if (!select) return;
        select.innerHTML = "";
        chars.forEach(char => {
          const option = document.createElement("option");
          option.value = char.id;
          option.textContent = char.name + (char.source ? " · " + char.source : "");
          option.selected = char.id === active;
          select.appendChild(option);
        });
      });
    }

    function renderCharacterLabels() {
      const name = getCharacterName();
      const iconHTML = makeCharacterIconHTML();

      if ($("talkCharacterName")) $("talkCharacterName").textContent = name;
      if ($("talkAvatar")) $("talkAvatar").innerHTML = iconHTML;
      if ($("chatCharacterNameLabel")) $("chatCharacterNameLabel").textContent = name;
      if ($("chatCharacterIcon")) $("chatCharacterIcon").innerHTML = iconHTML;

      document.querySelectorAll(".mini-avatar").forEach(el => {
        el.innerHTML = iconHTML;
      });
    }

    function selectDreamCharacter(id) {
      localStorage.setItem("activeDreamCharacterId", id);
      renderDreamCharacterSelect();
      renderCharacterLabels();
    renderTalkSettings();
      if (typeof renderMessages === "function") renderMessages();
      if (typeof renderTalk === "function") renderTalk();
    }

    async function saveDreamCharacter() {
      const name = $("newCharacterName").value.trim();
      const source = $("newCharacterSource").value.trim();
      const memo = $("newCharacterMemo").value.trim();
      const file = $("newCharacterImage").files[0];

      if (!name) {
        alert("드림 캐릭터 이름을 적어줘.");
        return;
      }

      const image = await readFileAsDataURL(file);
      const id = "char_" + Date.now();
      const chars = getDreamCharacters();
      chars.push({ id, name, source, memo, image });
      saveDreamCharacters(chars);
      localStorage.setItem("activeDreamCharacterId", id);

      ["newCharacterName","newCharacterSource","newCharacterMemo"].forEach(inputId => $(inputId).value = "");
      $("newCharacterImage").value = "";

      renderDreamCharacterSelect();
      renderCharacterLabels();
      alert("드림 캐릭터를 추가했어.");
    }



    function nyChatWasCleared() {
      return localStorage.getItem("nyChatCleared") === "yes";
    }

    function nyMarkChatCleared() {
      localStorage.setItem("nyChatCleared", "yes");
      [
        "nyDreamChatMessages",
        "dreamCharacterChatMessages",
        "dreamCharacterChatMessagesV2",
        "dreamCharacterChatMessagesV3",
        "soluluChatMessages"
      ].forEach(key => localStorage.removeItem(key));
    }

    function nySaveCurrentChatIfPossible() {
      try {
        if (typeof messages !== "undefined") {
          localStorage.setItem("nyDreamChatMessages", JSON.stringify(messages));
          localStorage.removeItem("nyChatCleared");
        }
      } catch (e) {}
    }

    function nyApplyChatClearFlag() {
      try {
        if (nyChatWasCleared() && typeof messages !== "undefined") {
          messages.length = 0;
        }
      } catch (e) {}
    }

    function nyTodoItemsOnly(entries) {
      return (entries || []).filter(item => item && item.dateKey && !String(item.body || "").trim());
    }


    function renderMessages() {
      nyApplyChatClearFlag();
      const box = $("chatBox");
      if (!box) return;
      box.innerHTML = "";
      if (messages.length === 0 && !chatIsTyping) {
        const empty = document.createElement("div");
        empty.className = "chat-empty";
        empty.textContent = "아직 주고받은 대화가 없어요.";
        box.appendChild(empty);
      }

      messages.forEach(msg => {
        const row = document.createElement("div");
        row.className = "msg-row " + (msg.role === "user" ? "user" : "bot");
        if (msg.role === "bot") {
          const av = document.createElement("div");
          av.className = "mini-avatar";
          av.innerHTML = makeCharacterIconHTML();
          row.appendChild(av);
        }
        const bubble = document.createElement("div");
        bubble.className = "bubble " + (msg.role === "user" ? "user-bubble" : "bot-bubble");
        bubble.textContent = msg.text;
        row.appendChild(bubble);
        box.appendChild(row);
      });

      if (chatIsTyping) {
        const row = document.createElement("div");
        row.className = "chat-typing-row";
        row.innerHTML = `
          <div class="mini-avatar">소</div>
          <div class="chat-typing-bubble">
            <span class="chat-typing-dot"></span>
            <span class="chat-typing-dot"></span>
            <span class="chat-typing-dot"></span>
          </div>
        `;
        box.appendChild(row);
      }

      box.scrollTop = box.scrollHeight;
    }

    function pickReply(text) {
      if (text.includes("지쳤") || text.includes("힘들") || text.includes("우울")) return solulu.sampleReply;
      if (text.includes("보고") || text.includes("좋아") || text.includes("그리")) return solulu.quick[2];
      if (text.includes("이야기") || text.includes("말")) return solulu.quick[0];
      return solulu.quick[Math.floor(Math.random() * solulu.quick.length)];
    }

    function buildSoluluSystemPrompt() {
      const settings = getBotSettings ? getBotSettings() : {};
      const modeGuide = {
        chat: "현재 모드는 채팅 모드다. 일상 대화처럼 자연스럽고 짧게 응답한다.",
        basic: "현재 모드는 베이직 모드다. 드림 관계를 과하게 밀지 말고, 원작 캐릭터성/말투/세계관을 우선한다.",
        dream: "현재 모드는 드림 모드다. 드림주와의 관계성, 호칭, 거리감, 감정선을 우선하되 과장하지 않는다."
      };

      return [
        "너는 현재 선택된 드림 캐릭터 역할로 대화한다. 기본 캐릭터는 소루루다.",
        "사용자가 입력한 캐릭터 해석과 말투 설정을 최우선으로 따른다.",
        "대답은 소루루가 직접 말하는 것처럼 작성한다. 메타발언, 시스템 설명, 'AI'라는 말은 하지 않는다.",
        "사용자가 모드를 바꿨다는 사실을 캐릭터가 말풍선 안에서 직접 언급하지 않는다.",
        modeGuide[botMode] || modeGuide.chat,
        "",
        "[캐릭터 설정]",
        settings.character || "(아직 상세 캐릭터 설정 없음)",
        "",
        "[말투 설정]",
        settings.speech || "(아직 말투 설정 없음)",
        "",
        "[대사 샘플]",
        settings.samples || "(아직 대사 샘플 없음)",
        "",
        "[세계관 지식 범위]",
        settings.world || "(아직 세계관 지식 범위 없음)",
        "",
        "[드림 모드 설정]",
        settings.dream || "(아직 드림 모드 설정 없음)"
      ].join("\n");
    }

    async function callChatApi(userText) {
      const settings = getBotSettings ? getBotSettings() : {};
      if (!settings.apiUrl) return null;

      const payload = {
        mode: botMode,
        character: getCharacterName(),
        systemPrompt: buildSoluluSystemPrompt(),
        messages: messages.map(m => ({
          role: m.role === "user" ? "user" : "assistant",
          content: m.text
        })),
        userMessage: userText
      };

      const response = await fetch(settings.apiUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });

      if (!response.ok) throw new Error("API response error");
      const data = await response.json();
      return data.reply || data.text || data.message || null;
    }

    async function sendChatMessage() {
      const input = $("chatInput");
      if (!input) return;
      const text = input.value.trim();
      if (!text || chatIsTyping) return;

      messages.push({ role: "user", text });
      nySaveCurrentChatIfPossible();
      input.value = "";

      chatIsTyping = true;
      input.disabled = true;
      renderMessages();

      try {
        let reply = await callChatApi(text);
        if (!reply) {
          const delay = Math.min(1600, Math.max(500, 360 + text.length * 25));
          await new Promise(resolve => setTimeout(resolve, delay));
          reply = makeSoluluReply(text);
        }
        messages.push({ role: "bot", text: reply });
        nySaveCurrentChatIfPossible();
      } catch (error) {
        messages.push({ role: "bot", text: "잠깐 연결이 흔들린 것 같아. 다시 한 번 말해줄래?" });
        nySaveCurrentChatIfPossible();
      } finally {
        chatIsTyping = false;
        if ($("chatInput")) $("chatInput").disabled = false;
        renderMessages();
      }
    }

    function sendMessage() {
      sendChatMessage();
    }

    function quickSend(text) {
      $("chatInput").value = text;
      sendChatMessage();
    }

    function getTodayKey() {
      const now = new Date();
      return `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
    }

    function normalizeDateKey(input) {
      const text = String(input || "").trim();
      if (!text) return "";
      let match = text.match(/(20\d{2})[.\-/ ]\s*(\d{1,2})[.\-/ ]\s*(\d{1,2})/);
      if (match) {
        const y = match[1];
        const m = String(match[2]).padStart(2, "0");
        const d = String(match[3]).padStart(2, "0");
        return `${y}-${m}-${d}`;
      }
      match = text.match(/(\d{1,2})\s*월\s*(\d{1,2})\s*일/);
      if (match) {
        const now = new Date();
        const y = String(now.getFullYear());
        const m = String(match[1]).padStart(2, "0");
        const d = String(match[2]).padStart(2, "0");
        return `${y}-${m}-${d}`;
      }
      match = text.match(/(\d{1,2})[.\-/ ]\s*(\d{1,2})/);
      if (match) {
        const now = new Date();
        const y = String(now.getFullYear());
        const m = String(match[1]).padStart(2, "0");
        const d = String(match[2]).padStart(2, "0");
        return `${y}-${m}-${d}`;
      }
      return "";
    }

    let calendarDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    let selectedDateKey = getTodayKey();
    let homeCalendarDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    let botMode = 'chat';

    function getDiaryEntries() {
      return JSON.parse(localStorage.getItem("shellDiary") || "[]");
    }

    function saveDiary() {
      const title = $("diaryTitle").value.trim();
      const date = $("diaryDate").value.trim();
      const body = $("diaryBody").value.trim();
      if (!title && !body) return;

      const entries = getDiaryEntries();
      const dateKey = normalizeDateKey(date) || selectedDateKey;
      entries.unshift({ title: title || "제목 없는 일정", date: date || dateKey, dateKey, body, done: false });
      localStorage.setItem("shellDiary", JSON.stringify(entries));

      ["diaryTitle","diaryDate","diaryBody"].forEach(id => $(id).value = "");
      selectedDateKey = dateKey;
      renderDiary();
      renderScheduleCalendar();
      renderHomeCalendar();
      renderTodoPanel();
    }


    function addTodoForSelectedDate() {
      const text = prompt("추가할 일정을 적어줘.");
      if (!text || !text.trim()) return;

      const entries = getDiaryEntries();
      entries.unshift({
        title: text.trim(),
        date: selectedDateKey,
        dateKey: selectedDateKey,
        body: "",
        type: "todo",
        done: false
      });
      localStorage.setItem("shellDiary", JSON.stringify(entries));
      renderDiary();
      renderScheduleCalendar();
      renderHomeCalendar();
      renderTodoPanel();
    }

    function toggleDiaryDone(index) {
      const entries = getDiaryEntries();
      if (!entries[index]) return;
      entries[index].done = !entries[index].done;
      localStorage.setItem("shellDiary", JSON.stringify(entries));
      renderDiary();
      renderTodoPanel();
      renderScheduleCalendar();
      renderHomeCalendar();
    }


    function deleteTodo(index) {
      const entries = getDiaryEntries();
      if (!entries[index]) return;
      if (!confirm("이 일정을 삭제할까?")) return;
      entries.splice(index, 1);
      localStorage.setItem("shellDiary", JSON.stringify(entries));
      renderDiary();
      renderScheduleCalendar();
      renderHomeCalendar();
      renderTodoPanel();
    }


    function deleteDiary(index) {
      const entries = getDiaryEntries();
      if (!entries[index]) return;
      if (!confirm("이 일기를 삭제할까?")) return;
      entries.splice(index, 1);

      // 저장소 이름이 버전마다 다를 수 있어서 현재 함수/기존 저장소 양쪽에 안전 저장
      if (typeof saveDiaryEntries === "function") {
        saveDiaryEntries(entries);
      } else {
        localStorage.setItem("shellDiary", JSON.stringify(entries));
      }

      renderDiary();
    }


    function renderDiary() {
      const list = $("diaryList");
      if (!list) return;
      const diaries = getDiaryEntries();
      if (diaries.length === 0) {
        list.innerHTML = `<div class="entry"><h4 class="serif">Secret Diary</h4><p>아직 비밀일기가 없어요.</p></div>`;
        return;
      }
      list.innerHTML = "";
      diaries.forEach((diary, index) => {
        const card = document.createElement("div");
        card.className = "entry";
        card.innerHTML = `
          <h4 class="serif">${escapeHtml(diary.title)}</h4>
          <p>${escapeHtml(diary.body || "")}</p>
          <div class="tag-row">
            <span class="tag">${escapeHtml(diary.date || "")}</span>
            <button class="diary-delete-btn" type="button" onclick="deleteDiary(${index})">delete</button>
          </div>
        `;
        list.appendChild(card);
      });
    }

    function getEntriesForDate(dateKey) {
      return getDiaryEntries()
        .map((entry, index) => ({...entry, index}))
        .filter(entry => entry.dateKey === dateKey && !String(entry.body || "").trim());
    }

    function getShellIcon() {
      return `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 20c-3.8 0-7.4-1.5-10-4.1 1.3-.8 2.6-1.5 4-2 .6-4 3-7.2 6-8.9 3 1.7 5.4 4.9 6 8.9 1.4.5 2.7 1.2 4 2C19.4 18.5 15.8 20 12 20zm0-11.6c-1.9 1.3-3.4 3.4-4 6 .7-.1 1.3-.2 2-.2h4c.7 0 1.3.1 2 .2-.6-2.6-2.1-4.7-4-6z"/></svg>`;
    }

    function renderScheduleCalendar() {
      const grid = $("secretCalendarGrid");
      const note = $("secretCalendarNote");
      if (!grid) return;

      const year = calendarDate.getFullYear();
      const month = calendarDate.getMonth();
      $("calendarYearLabel").textContent = year;
      $("calendarMonthLabel").textContent = new Date(year, month, 1).toLocaleString("en-US", { month: "long" });

      const firstDay = new Date(year, month, 1);
      const startWeekday = firstDay.getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const prevDays = new Date(year, month, 0).getDate();
      const allEntries = nyTodoItemsOnly(getDiaryEntries());
      const countFor = key => allEntries.filter(entry => entry.dateKey === key).length;

      grid.innerHTML = "";

      ["일","월","화","수","목","금","토"].forEach(day => {
        const el = document.createElement("div");
        el.className = "calendar-weekday";
        el.textContent = day;
        grid.appendChild(el);
      });

      const todayKey = getTodayKey();
      const cells = 42;

      for (let i = 0; i < cells; i++) {
        let dayNum;
        let cellMonth = month;
        let cellYear = year;
        let other = false;

        if (i < startWeekday) {
          dayNum = prevDays - startWeekday + i + 1;
          cellMonth = month - 1;
          if (cellMonth < 0) {
            cellMonth = 11;
            cellYear -= 1;
          }
          other = true;
        } else if (i >= startWeekday + daysInMonth) {
          dayNum = i - (startWeekday + daysInMonth) + 1;
          cellMonth = month + 1;
          if (cellMonth > 11) {
            cellMonth = 0;
            cellYear += 1;
          }
          other = true;
        } else {
          dayNum = i - startWeekday + 1;
        }

        const key = `${cellYear}-${String(cellMonth + 1).padStart(2, "0")}-${String(dayNum).padStart(2, "0")}`;
        const count = countFor(key);
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className =
          "calendar-day" +
          (other ? " other-month" : "") +
          (key === todayKey ? " today" : "") +
          (key === selectedDateKey ? " selected" : "");

        const icons = count > 0
          ? `<div class="shell-indicators">${Array.from({ length: Math.min(count, 3) }).map(() => getShellIcon()).join("")}${count > 3 ? `<span class="shell-more">+${count - 3}</span>` : ""}</div>`
          : `<div class="shell-indicators"></div>`;

        btn.innerHTML = `<span class="day-number">${dayNum}</span>${icons}`;
        btn.onclick = () => {
          selectedDateKey = key;
          calendarDate = new Date(cellYear, cellMonth, 1);
          renderScheduleCalendar();
          renderTodoPanel();
        };
        grid.appendChild(btn);
      }

      note.textContent = allEntries.length ? "날짜를 누르면 일정을 볼 수 있어요." : "아직 일정이 없어요.";
    }

    function formatDateLabel(dateKey) {
      if (!dateKey) return "아직 일정이 없어요.";
      const [y, m, d] = dateKey.split('-');
      return `${Number(m)}월 ${Number(d)}일`;
    }

    function renderTodoPanel() {
      const panel = $("todoListPanel");
      const entries = getEntriesForDate(selectedDateKey);
      $("todoBoardDate").textContent = entries.length ? `${formatDateLabel(selectedDateKey)} · ${entries.length}개의 일정` : `${formatDateLabel(selectedDateKey)} · 아직 일정이 없어요.`;
      if (!entries.length) {
        panel.innerHTML = `<div class="todo-empty">아직 일정이 없어요.</div>`;
        return;
      }
      panel.innerHTML = "";
      entries.forEach(entry => {
        const item = document.createElement("div");
        item.className = "todo-item" + (entry.done ? " done" : "");
        item.innerHTML = `<div><div class="todo-title">${escapeHtml(entry.title)}</div><div class="todo-note">${escapeHtml(entry.body || '')}</div></div><button type="button" class="todo-check ${entry.done ? 'done' : ''}" onclick="toggleDiaryDone(${entry.index})">✓</button><button type="button" class="todo-delete" onclick="deleteTodo(${entry.index})">×</button>`;
        panel.appendChild(item);
      });
    }


