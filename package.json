  <script>
    window.__nyPendingClear = "";

    function nyOpenModal(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.classList.add("open");
      el.style.display = "grid";
      var input = id === "nyEditGate" ? document.getElementById("nyEditPassword") : document.getElementById("nyClearPassword");
      if (input) {
        input.value = "";
        setTimeout(function(){ input.focus(); }, 50);
      }
    }

    function nyCloseModal(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.classList.remove("open");
      el.style.display = "none";
      if (id === "nyClearGate") window.__nyPendingClear = "";
    }

    function nyOpenEdit() {
      nyOpenModal("nyEditGate");
    }

    function nyConfirmEdit() {
      var input = document.getElementById("nyEditPassword");
      if (!input || input.value.trim() !== "ribbon") {
        alert("비밀번호가 달라!");
        return;
      }
      nyCloseModal("nyEditGate");
      document.body.classList.add("edit-mode");
      var viewer = document.getElementById("viewerBtn");
      var edit = document.getElementById("editBtn");
      if (viewer) viewer.classList.remove("active");
      if (edit) edit.classList.add("active");
      if (typeof setMode === "function") setMode("edit");
    }

    function nyOpenClear(target) {
      window.__nyPendingClear = target;
      var title = document.getElementById("nyClearTitle");
      var text = document.getElementById("nyClearText");
      if (title) title.textContent = target + " clear";
      if (text) text.textContent = target + " 내용을 삭제하려면 비밀번호를 입력해줘.";
      nyOpenModal("nyClearGate");
    }

    function nyConfirmClear() {
      var input = document.getElementById("nyClearPassword");
      if (!input || input.value.trim() !== "ribbon") {
        alert("비밀번호가 달라!");
        return;
      }

      if (window.__nyPendingClear === "Chat") {
        nyMarkChatCleared();
        try { if (typeof chatReplyTimer !== "undefined") clearTimeout(chatReplyTimer); } catch(e) {}
        try { if (typeof chatIsTyping !== "undefined") chatIsTyping = false; } catch(e) {}
        try { if (typeof messages !== "undefined") messages.length = 0; } catch(e) {}
        ["dreamCharacterChatMessages","dreamCharacterChatMessagesV2","dreamCharacterChatMessagesV3","soluluChatMessages"].forEach(function(key){ localStorage.removeItem(key); });
        var chatInput = document.getElementById("chatInput");
        if (chatInput) chatInput.disabled = false;
        try { if (typeof renderMessages === "function") renderMessages(); } catch(e) {}
      }

      if (window.__nyPendingClear === "Talk") {
        try { if (typeof talkReplyTimer !== "undefined") clearTimeout(talkReplyTimer); } catch(e) {}
        try { if (typeof talkIsTyping !== "undefined") talkIsTyping = false; } catch(e) {}
        try { if (typeof talkMessages !== "undefined") talkMessages.length = 0; } catch(e) {}
        ["soluluTalkMessages","soluluTalkMessagesV2","soluluTalkMessagesStable","dreamCharacterTalkMessages","dreamCharacterTalkMessagesV3","dreamCharacterTalkMessagesApiReady"].forEach(function(key){ localStorage.removeItem(key); });
        var talkInput = document.getElementById("talkInput");
        if (talkInput) talkInput.disabled = false;
        try { if (typeof renderTalk === "function") renderTalk(); } catch(e) {}
      }

      nyCloseModal("nyClearGate");
    }

    document.addEventListener("keydown", function(e) {
      if (e.key === "Enter") {
        if (document.getElementById("nyEditGate") && document.getElementById("nyEditGate").classList.contains("open")) nyConfirmEdit();
        if (document.getElementById("nyClearGate") && document.getElementById("nyClearGate").classList.contains("open")) nyConfirmClear();
      }
    });
  </script>

